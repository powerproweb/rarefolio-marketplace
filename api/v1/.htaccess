# Rarefolio Public API v1 — Front Controller
#
# Routes every request under /api/v1/* through index.php so the PHP router
# can dispatch on path + method. Works whether the app is at domain root or
# a subpath (e.g. market.rarefolio.io/api/v1 vs rarefolio.io/api/v1).

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Let real files pass through (useful for static assets if ever added)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Everything else -> index.php
  RewriteRule ^ index.php [QSA,L]
</IfModule>

# Defensive headers (some also set by the PHP layer)
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "no-referrer"
  Header always set X-Frame-Options "DENY"
</IfModule>

# Never serve the PHP sources directly
<FilesMatch "\.(env|ini|log|sql|md)$">
  Require all denied
</FilesMatch>
