# =============================================================================
#  Rarefolio Marketplace — Environment Configuration (template)
# =============================================================================
#  Copy to .env and fill in real values:
#      Copy-Item .env.example .env
#
#  NEVER commit the real .env. It is already in .gitignore.
#  See docs/CONFIG.md for the full setup walkthrough.
# =============================================================================


# -----------------------------------------------------------------------------
#  1. App
# -----------------------------------------------------------------------------
# APP_ENV     : local | staging | production
# APP_DEBUG   : true in local only; false everywhere else
# APP_URL     : the URL at which the marketplace is served
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080


# -----------------------------------------------------------------------------
#  2. Database (MySQL 8 / MariaDB 10.6+)
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rarefolio
DB_USER=rarefolio
DB_PASS=change_me


# -----------------------------------------------------------------------------
#  3. Blockfrost (Cardano chain access)
# -----------------------------------------------------------------------------
# Get a project key from https://blockfrost.io/
# BLOCKFROST_NETWORK : preprod (testing) | mainnet (production)
BLOCKFROST_NETWORK=preprod
BLOCKFROST_API_KEY=preprod_your_key_here


# -----------------------------------------------------------------------------
#  4. Node.js sidecar (Cardano tx building)
# -----------------------------------------------------------------------------
SIDECAR_BASE_URL=http://localhost:4000


# -----------------------------------------------------------------------------
#  5. Admin auth (Phase 1 — replace with proper auth in Phase 2)
# -----------------------------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASS=change_me


# -----------------------------------------------------------------------------
#  6. Public API v1 — CORS whitelist
# -----------------------------------------------------------------------------
# This is NOT a secret. It is a comma-separated list of exact origins (scheme
# + host, no trailing slash, no path, no wildcards) that the browser on the
# main site is allowed to call from.
#
# Production:
#   CORS_ALLOWED_ORIGINS=https://rarefolio.io,https://www.rarefolio.io
#
# Local dev (serving main site on localhost:8080):
#   CORS_ALLOWED_ORIGINS=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080


# -----------------------------------------------------------------------------
#  7. Public API v1 — rate limiting
# -----------------------------------------------------------------------------
# Per-IP token bucket. Set capacity or window to 0 to disable the limiter
# entirely (not recommended in production).
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_WINDOW_SECONDS=60

# If the API runs behind a reverse proxy / CDN (Cloudflare, nginx, etc.),
# uncomment the line below with the header that carries the real client IP.
# Leave commented if requests arrive directly from the browser.
# TRUSTED_PROXY_HEADER=X-Forwarded-For


# -----------------------------------------------------------------------------
#  8. Outbound webhooks (marketplace -> main site)
# -----------------------------------------------------------------------------
# Base URL of the main site's webhook endpoints. The sender appends the event
# name + ".php", so these files must exist on the main site:
#   <base>/mint-complete.php
#   <base>/ownership-change.php
PUBLIC_SITE_WEBHOOK_URL_BASE=https://rarefolio.io/api/webhook

# Shared HMAC secret. MUST be identical to RF_WEBHOOK_SECRET on the main site.
# This IS a secret. Generate a fresh one with:
#   php scripts/gen-webhook-secret.php
# or:
#   openssl rand -hex 32
PUBLIC_SITE_WEBHOOK_SECRET=change_me_generate_a_long_random_string


# -----------------------------------------------------------------------------
#  9. Inbound Blockfrost webhooks (Blockfrost → marketplace)
# -----------------------------------------------------------------------------
# Auth token provided by Blockfrost when you register a webhook at:
#   https://blockfrost.io/dashboard/webhooks
# Register your split wallet address(es) to trigger the auto-sweep.
# This IS a secret. NEVER commit the real value.
BLOCKFROST_WEBHOOK_AUTH_TOKEN=change_me_from_blockfrost_dashboard


# -----------------------------------------------------------------------------
#  10. Private server-to-server verification (main site -> marketplace)
# -----------------------------------------------------------------------------
# Shared secret for /api/private/ownership-verify.php
# The main site sends this as: Authorization: Bearer <secret>
DOWNLOAD_VERIFY_SHARED_SECRET=change_me_generate_a_long_random_string
